<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<!--
  reproductor.fxml
  Ubicación esperada: src/main/resources/player/reproductor.fxml
-->
<StackPane
    fx:id="rootPane"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="player.controllers.ReproductorController"
    style="-fx-background-color: #0a0a0f;"
    prefWidth="960" prefHeight="580"
    xmlns="http://javafx.com/javafx/17">

    <!-- ── Superficie de video ─────────────────────────────── -->
    <ImageView
        fx:id="videoView"
        fitWidth="960" fitHeight="580"
        preserveRatio="true"
        mouseTransparent="true"/>

    <!-- ── Overlay de controles (aparece/desaparece) ──────── -->
    <VBox
        fx:id="controlesBox"
        alignment="BOTTOM_CENTER"
        style="-fx-background-color: transparent;">

        <!-- Barra superior con título -->
        <HBox
            alignment="CENTER_LEFT"
            style="-fx-background-color: linear-gradient(to bottom, rgba(0,0,0,0.75), transparent);">
            <padding>
                <Insets top="12" right="20" bottom="24" left="20"/>
            </padding>
            <Label
                fx:id="lblTitulo"
                text="Sin reproducción"
                styleClass="lbl-titulo"/>
        </HBox>

        <!-- Spacer central -->
        <Region VBox.vgrow="ALWAYS"/>

        <!-- Barra de buffering -->
        <ProgressBar
            fx:id="bufferingBar"
            maxWidth="Infinity"
            progress="-1"
            visible="false"
            styleClass="buffering-bar"/>

        <!-- Panel de controles inferior -->
        <VBox
            fx:id="barraControles"
            style="-fx-background-color: linear-gradient(to top, rgba(0,0,0,0.88), transparent);"
            spacing="6">
            <padding>
                <Insets top="20" right="20" bottom="14" left="20"/>
            </padding>

            <!-- Slider de progreso -->
            <HBox alignment="CENTER" spacing="10">
                <Label fx:id="lblTiempoActual" text="00:00:00" styleClass="lbl-tiempo"/>
                <Slider
                    fx:id="sliderProgreso"
                    HBox.hgrow="ALWAYS"
                    styleClass="slider-progreso"
                    min="0" max="100" value="0"/>
                <Label fx:id="lblTiempoTotal" text="00:00:00" styleClass="lbl-tiempo"/>
            </HBox>

            <!-- Fila de botones -->
            <HBox alignment="CENTER" spacing="8">

                <!-- Controles de reproducción -->
                <Button fx:id="btnDetener"   text="&#9209;" styleClass="btn-control" onAction="#onDetener"/>
                <Button                       text="&#9198;" styleClass="btn-control" onAction="#onRetroceder"/>
                <Button fx:id="btnPlayPause" text="&#9654;" styleClass="btn-control btn-play" onAction="#onPlayPause"/>
                <Button                       text="&#9197;" styleClass="btn-control" onAction="#onAdelantar"/>

                <!-- Separador -->
                <Region HBox.hgrow="ALWAYS"/>

                <!-- Estado -->
                <Label fx:id="lblEstado" text="" styleClass="lbl-estado"/>

                <!-- Volumen -->
                <Button fx:id="btnMute" text="&#128266;" styleClass="btn-control" onAction="#onMute"/>
                <Slider
                    fx:id="sliderVolumen"
                    styleClass="slider-volumen"
                    prefWidth="90"
                    min="0" max="100" value="80"/>

                <!-- Separador -->
                <Region prefWidth="12"/>

                <!-- Abrir archivo -->
                <Button fx:id="btnAbrir" text="&#128194;" styleClass="btn-control" onAction="#onAbrir"/>

                <!-- Pantalla completa -->
                <Button fx:id="btnPantallaCompleta" text="&#x26F6;" styleClass="btn-control"
                        onAction="#onPantallaCompleta"/>
            </HBox>
        </VBox>
    </VBox>
</StackPane>